// ntrack — live location sharing over Nostr (kind:3434)
//
// Single-window phone UI with four pages and a bottom tab bar.
// All data shown here is pushed from Rust as ready-to-render strings/models;
// all interaction flows back through callbacks.

import { LineEdit, ComboBox, ScrollView, Palette } from "std-widgets.slint";

export struct GroupItem {
    id: string,          // recipient pseudonym pubkey, hex
    name: string,
    npub: string,        // shortened npub for display
    can-receive: bool,
    selected: bool,
}

export struct TrackItem {
    sender: string,      // sender pubkey hex (stable id)
    title: string,       // label, sender's name, or derived handle
    label: string,       // raw user label ("" when unset)
    npub: string,        // shortened npub (identity, shown under the title)
    group: string,
    status: string,      // "LIVE" | "ENDED"
    coords: string,
    ago: string,
    msg: string,
    color: color,        // accent derived from the sender key
    live: bool,
    has-coords: bool,
    alert: bool,         // sender is broadcasting a duress alert
}

export struct RelayItem {
    url: string,
    connected: bool,
}

// One OSM raster tile placed on the live map. `dx`/`dy` are the tile's
// top-left offset (px) from the map centre; Rust keeps the tile cache.
export struct MapTile {
    dx: length,
    dy: length,
    img: image,
}

// A peer's live position. `dx`/`dy` offset (px) from the map centre; `color`
// is the same key-derived accent shown on the Track card.
export struct MapMarker {
    dx: length,
    dy: length,
    color: color,
    label: string,
}

global Theme {
    out property <color> bg: #0f1117;
    out property <color> card: #1a1d27;
    out property <color> card-alt: #232736;
    out property <color> accent: #8b5cf6;
    out property <color> accent-dim: #6d45cc;
    out property <color> text: #e8eaf2;
    out property <color> muted: #9aa0b4;
    out property <color> ok: #3ddc84;
    out property <color> warn: #ffb347;
    out property <color> danger: #ff5566;
    out property <color> line: #2a2e3f;
    out property <length> pad: 16px;
    out property <length> radius: 14px;
}

component Card inherits Rectangle {
    background: Theme.card;
    border-radius: Theme.radius;
    clip: true;
}

component AppButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> stop: false;
    in property <bool> warn: false;
    in property <bool> enabled: true;
    callback clicked;

    height: 46px;
    border-radius: 12px;
    background: !self.enabled ? Theme.card-alt
        : self.danger ? Theme.danger.darker(20%)
        : self.stop ? Theme.danger.darker(40%)
        : self.warn ? (touch.pressed ? Theme.warn.darker(15%) : Theme.warn)
        : self.primary ? (touch.pressed ? Theme.accent-dim : Theme.accent)
        : (touch.pressed ? Theme.card-alt.brighter(15%) : Theme.card-alt);

    Text {
        text: root.text;
        color: !root.enabled ? Theme.muted
            : root.warn ? Theme.bg
            : (root.primary || root.danger || root.stop) ? #ffffff
            : Theme.text;
        font-size: 15px;
        font-weight: 600;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component SmallButton inherits Rectangle {
    in property <string> text;
    in property <bool> danger: false;
    callback clicked;
    height: 30px;
    width: label.preferred-width + 20px;
    border-radius: 8px;
    background: t.pressed ? Theme.card-alt.brighter(20%) : Theme.card-alt;
    border-width: 1px;
    border-color: root.danger ? Theme.danger.darker(10%) : Theme.line;
    label := Text {
        text: root.text;
        color: root.danger ? Theme.danger : Theme.text;
        font-size: 12px;
        vertical-alignment: center;
        horizontal-alignment: center;
    }
    t := TouchArea { clicked => { root.clicked(); } }
}

component StatusDot inherits Rectangle {
    in property <bool> on;
    in property <color> on-color: Theme.ok;
    width: 10px;
    height: 10px;
    border-radius: 5px;
    background: root.on ? root.on-color : #555b70;
}

component SectionTitle inherits Text {
    color: Theme.muted;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1px;
}

component Toggle inherits Rectangle {
    in property <bool> checked;
    callback toggled(bool);
    width: 44px;
    height: 26px;
    border-radius: 13px;
    background: root.checked ? Theme.accent : Theme.card-alt;
    animate background { duration: 120ms; }
    Rectangle {
        x: root.checked ? parent.width - self.width - 3px : 3px;
        y: 3px;
        width: 20px;
        height: 20px;
        border-radius: 10px;
        background: #ffffff;
        animate x { duration: 120ms; }
    }
    TouchArea { clicked => { root.toggled(!root.checked); } }
}

// ---------------------------------------------------------------- pages --

component SharePage inherits ScrollView {
    in property <[GroupItem]> groups;
    in property <bool> sharing;
    in property <bool> waiting-fix;
    in property <string> status-headline;
    in property <string> status-detail;
    in property <int> interval-index;
    in property <bool> location-permission;
    in property <bool> alert;
    in property <bool> checkin-armed;
    in property <bool> checkin-grace;
    in property <string> checkin-countdown;

    callback toggle-group(string, bool);
    callback start-share(string);
    callback stop-share();
    callback set-interval(int);
    callback message-edited(string);
    callback panic();
    callback clear-alert();
    callback arm-checkin(int);
    callback checkin-safe();
    callback checkin-disarm();

    VerticalLayout {
        padding: Theme.pad;
        spacing: 12px;
        alignment: start;

        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 6px;
                HorizontalLayout {
                    spacing: 8px;
                    VerticalLayout {
                        alignment: center;
                        StatusDot {
                            on: root.sharing;
                            on-color: root.waiting-fix ? Theme.warn : Theme.ok;
                        }
                    }
                    Text {
                        text: root.status-headline;
                        color: Theme.text;
                        font-size: 18px;
                        font-weight: 700;
                        wrap: word-wrap;
                    }
                }
                Text {
                    text: root.status-detail;
                    color: Theme.muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }
        }

        SectionTitle { text: "SHARE WITH"; }
        Card {
            VerticalLayout {
                padding: 8px;
                if root.groups.length == 0 : VerticalLayout {
                    padding: 8px;
                    Text {
                        text: "No groups yet — create one in the Groups tab.";
                        color: Theme.muted;
                        font-size: 13px;
                        wrap: word-wrap;
                    }
                }
                for g[i] in root.groups : HorizontalLayout {
                    padding: 8px;
                    spacing: 10px;
                    VerticalLayout {
                        alignment: center;
                        Toggle {
                            checked: g.selected;
                            toggled(v) => { root.toggle-group(g.id, v); }
                        }
                    }
                    VerticalLayout {
                        Text { text: g.name; color: Theme.text; font-size: 15px; }
                        Text { text: g.npub; color: Theme.muted; font-size: 11px; }
                    }
                }
            }
        }

        // ---- check-in (dead-man's switch) ----
        SectionTitle { text: "CHECK-IN"; }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;

                if root.checkin-grace : Rectangle {
                    border-radius: 10px;
                    background: Theme.danger.darker(35%);
                    VerticalLayout {
                        padding: 10px;
                        spacing: 6px;
                        Text {
                            text: "Check-in lapsed while you were away";
                            color: #ffffff;
                            font-size: 14px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                        Text {
                            text: "Confirm you're safe in " + root.checkin-countdown + ", or an alert is sent.";
                            color: #ffe8ea;
                            font-size: 12px;
                            wrap: word-wrap;
                        }
                    }
                }

                if root.checkin-armed && !root.checkin-grace : Text {
                    text: "Checking in — " + root.checkin-countdown + " left. Confirm you're safe to reset it, or an alert is sent to your groups. The timer repeats until you disarm.";
                    color: Theme.text;
                    font-size: 13px;
                    wrap: word-wrap;
                }

                if root.checkin-armed : HorizontalLayout {
                    spacing: 10px;
                    AppButton {
                        text: "I'm safe ✅";
                        primary: true;
                        clicked => { root.checkin-safe(); }
                    }
                    AppButton {
                        text: "Disarm";
                        clicked => { root.checkin-disarm(); }
                    }
                }

                if !root.checkin-armed : Text {
                    text: "Arm a repeating timer: if you don't confirm you're safe before it runs out, ntrack starts sharing and raises an alert to your groups. Confirming resets it; it runs until you disarm.";
                    color: Theme.muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
                if !root.checkin-armed : HorizontalLayout {
                    spacing: 10px;
                    checkin-box := ComboBox {
                        horizontal-stretch: 1;
                        model: ["15 min", "30 min", "1 h", "3 h", "6 h", "12 h", "24 h"];
                        current-index: 0;
                    }
                    AppButton {
                        text: "Arm";
                        warn: true;
                        min-width: 120px;
                        clicked => { root.arm-checkin(checkin-box.current-index); }
                    }
                }
            }
        }

        SectionTitle { text: "OPTIONS"; }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                msg-input := LineEdit {
                    placeholder-text: "Optional message (e.g. \"on my way\")";
                    enabled: true;
                    edited(text) => { root.message-edited(text); }
                }
                HorizontalLayout {
                    spacing: 10px;
                    Text {
                        text: "Update every";
                        color: Theme.text;
                        font-size: 14px;
                        vertical-alignment: center;
                    }
                    interval-box := ComboBox {
                        model: ["15 s", "30 s", "1 min", "5 min"];
                        current-index: root.interval-index;
                        selected => { root.set-interval(self.current-index); }
                    }
                }
            }
        }

        AppButton {
            text: root.sharing ? "Stop sharing" : "Start sharing";
            primary: !root.sharing;
            // a deeper red than the "Raise alert" button below, so the two aren't identical
            stop: root.sharing;
            clicked => {
                if (root.sharing) {
                    root.stop-share();
                } else {
                    root.start-share(msg-input.text);
                }
            }
        }

        // ---- duress alert ----
        if root.alert : Card {
            background: Theme.danger.darker(35%);
            VerticalLayout {
                padding: Theme.pad;
                spacing: 8px;
                Text {
                    text: "🚨 Alert active";
                    color: #ffffff;
                    font-size: 17px;
                    font-weight: 800;
                }
                Text {
                    text: "Your group is being notified and your location is updating quickly. Clear it once you're safe.";
                    color: #ffe8ea;
                    font-size: 13px;
                    wrap: word-wrap;
                }
                AppButton {
                    text: "Clear alert — I'm safe";
                    clicked => { root.clear-alert(); }
                }
            }
        }
        if !root.alert : AppButton {
            text: "Raise alert";
            danger: true;
            clicked => { root.panic(); }
        }
    }
}

component TrackRow inherits Card {
    in property <TrackItem> item;
    callback open-map();
    callback export-track();
    callback rename();

    HorizontalLayout {
        // Identity accent stripe: a colour derived from the sender key, the
        // disambiguator when two senders happen to share a name. A duress alert
        // overrides it with a wider danger-red stripe.
        Rectangle {
            width: item.alert ? 9px : 6px;
            background: item.alert ? Theme.danger : item.color;
        }
        VerticalLayout {
            padding: Theme.pad;
            spacing: 6px;
            HorizontalLayout {
                spacing: 8px;
                VerticalLayout {
                    alignment: center;
                    StatusDot {
                        on: item.live;
                        on-color: Theme.ok;
                    }
                }
                Text {
                    text: item.title;
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
                Rectangle {
                    width: badge.preferred-width + 16px;
                    height: 22px;
                    border-radius: 11px;
                    background: item.alert ? Theme.danger.darker(20%)
                        : item.live ? Theme.ok.darker(60%) : Theme.card-alt;
                    badge := Text {
                        text: item.alert ? "⚠ ALERT" : item.status;
                        color: item.alert ? #ffffff : (item.live ? Theme.ok : Theme.muted);
                        font-size: 11px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
            // Short npub under the friendly name, so the pseudonymous identity
            // stays verifiable even when two senders share a name.
            Text {
                text: item.npub;
                color: Theme.muted;
                font-size: 11px;
                overflow: elide;
            }
            Text { text: "Group: " + item.group; color: Theme.muted; font-size: 12px; }
            if item.has-coords : Text {
                text: item.coords;
                color: Theme.text;
                font-size: 13px;
            }
            if item.msg != "" : Text {
                text: "“" + item.msg + "”";
                color: Theme.warn;
                font-size: 13px;
                wrap: word-wrap;
            }
            HorizontalLayout {
                spacing: 8px;
                Text {
                    text: item.ago;
                    color: Theme.muted;
                    font-size: 12px;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
                SmallButton { text: "Rename"; clicked => { root.rename(); } }
                if item.has-coords : SmallButton { text: "Open map"; clicked => { root.open-map(); } }
                if item.has-coords : SmallButton { text: "Export"; clicked => { root.export-track(); } }
            }
        }
    }
}

component TrackPage inherits ScrollView {
    in property <[TrackItem]> tracks;
    in property <bool> can-receive-any;
    callback open-map(int);
    callback export-track(int);
    callback rename-request(string, string); // sender hex, current title

    VerticalLayout {
        padding: Theme.pad;
        spacing: 12px;
        alignment: start;
        if !root.can-receive-any : Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 6px;
                Text { text: "Not receiving"; color: Theme.text; font-size: 16px; font-weight: 700; }
                Text {
                    text: "To receive locations you need a group whose secret key you hold: create a group or import an nsec in the Groups tab.";
                    color: Theme.muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }
        }
        if root.can-receive-any && root.tracks.length == 0 : Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 6px;
                Text { text: "Listening…"; color: Theme.text; font-size: 16px; font-weight: 700; }
                Text {
                    text: "Live locations shared with your groups will appear here.";
                    color: Theme.muted;
                    font-size: 13px;
                    wrap: word-wrap;
                }
            }
        }
        for t[i] in root.tracks : TrackRow {
            item: t;
            open-map => { root.open-map(i); }
            export-track => { root.export-track(i); }
            rename => { root.rename-request(t.sender, t.label); }
        }
    }
}

component GroupRow inherits Card {
    in property <GroupItem> item;
    callback share-key();
    callback rotate-key();
    callback delete-group();

    VerticalLayout {
        padding: Theme.pad;
        spacing: 8px;
        HorizontalLayout {
            spacing: 8px;
            Text {
                text: item.name;
                color: Theme.text;
                font-size: 16px;
                font-weight: 700;
                overflow: elide;
                horizontal-stretch: 1;
            }
            Rectangle {
                width: kind.preferred-width + 16px;
                height: 22px;
                border-radius: 11px;
                background: item.can-receive ? Theme.accent.darker(60%) : Theme.card-alt;
                kind := Text {
                    text: item.can-receive ? "member" : "send-only";
                    color: item.can-receive ? Theme.accent.brighter(40%) : Theme.muted;
                    font-size: 11px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        Text { text: item.npub; color: Theme.muted; font-size: 12px; }
        HorizontalLayout {
            spacing: 8px;
            alignment: start;
            SmallButton { text: "Share key"; clicked => { root.share-key(); } }
            if item.can-receive : SmallButton { text: "Rotate"; clicked => { root.rotate-key(); } }
            SmallButton { text: "Delete"; danger: true; clicked => { root.delete-group(); } }
        }
    }
}

component GroupsPage inherits ScrollView {
    in property <[GroupItem]> groups;
    // Two-way bound to the import form so an incoming invite (scan / deep
    // link) can pre-fill these from Rust.
    in-out property <string> import-name-text;
    in-out property <string> import-key-text;
    callback create-group(string);
    callback import-group(string, string);
    callback share-group(string);
    callback rotate-group(string);
    callback delete-group(string);
    callback scan-qr();
    callback paste();

    VerticalLayout {
        padding: Theme.pad;
        spacing: 12px;
        alignment: start;

        SectionTitle { text: "CREATE NEW GROUP"; }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                new-name := LineEdit { placeholder-text: "Group name (e.g. Family)"; }
                AppButton {
                    text: "Create group";
                    primary: true;
                    clicked => {
                        root.create-group(new-name.text);
                        // Drop focus before the QR dialog opens so the input
                        // caret doesn't blink through it.
                        new-name.clear-focus();
                        new-name.text = "";
                    }
                }
            }
        }

        SectionTitle { text: "JOIN EXISTING GROUP"; }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                HorizontalLayout {
                    spacing: 10px;
                    AppButton {
                        text: "Scan QR 📷";
                        clicked => { root.scan-qr(); }
                    }
                    AppButton {
                        text: "Paste 📋";
                        clicked => { root.paste(); }
                    }
                }
                import-name := LineEdit {
                    placeholder-text: "Group name";
                    text <=> root.import-name-text;
                }
                import-key := LineEdit {
                    placeholder-text: "Paste an invite, nsec1… or npub1…";
                    text <=> root.import-key-text;
                }
                AppButton {
                    text: "Import key";
                    primary: true;
                    clicked => {
                        root.import-group(import-name.text, import-key.text);
                        import-name.text = "";
                        import-key.text = "";
                    }
                }
            }
        }

        SectionTitle { text: "YOUR GROUPS"; }
        if root.groups.length == 0 : Text {
            text: "A group is a shared key: everyone holding the secret can see locations sent to it.";
            color: Theme.muted;
            font-size: 13px;
            wrap: word-wrap;
        }
        for g[i] in root.groups : GroupRow {
            item: g;
            share-key => { root.share-group(g.id); }
            rotate-key => { root.rotate-group(g.id); }
            delete-group => { root.delete-group(g.id); }
        }
    }
}

component SettingsPage inherits ScrollView {
    in property <[RelayItem]> relays;
    in property <string> sender-npub;
    in property <string> display-name;   // configured name ("" when unset)
    in property <string> default-name;   // handle derived from the sender key
    callback add-relay(string);
    callback remove-relay(string);
    callback rotate-sender();
    callback set-display-name(string);

    VerticalLayout {
        padding: Theme.pad;
        spacing: 12px;
        alignment: start;

        SectionTitle { text: "YOUR NAME"; }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 8px;
                name-input := LineEdit {
                    placeholder-text: root.default-name == "" ? "Your name" : root.default-name;
                    // Pre-fill once on open; not bound, so the 1 s re-render
                    // never clobbers the field while you type.
                    init => { self.text = root.display-name; }
                    accepted(t) => { root.set-display-name(t); }
                }
                Text {
                    text: root.default-name == ""
                        ? "Shown to everyone you share your location with. Until you set one, a name is derived from your sender key."
                        : "Shown to everyone you share with. Leave blank to use the auto name “" + root.default-name + "”.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                AppButton {
                    text: "Save name";
                    clicked => {
                        root.set-display-name(name-input.text);
                        name-input.clear-focus();
                    }
                }
            }
        }

        SectionTitle { text: "RELAYS"; }
        Card {
            VerticalLayout {
                padding: 8px;
                for r[i] in root.relays : HorizontalLayout {
                    padding: 8px;
                    spacing: 10px;
                    VerticalLayout {
                        alignment: center;
                        StatusDot { on: r.connected; }
                    }
                    Text {
                        text: r.url;
                        color: Theme.text;
                        font-size: 13px;
                        overflow: elide;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }
                    SmallButton { text: "Remove"; danger: true; clicked => { root.remove-relay(r.url); } }
                }
            }
        }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                relay-input := LineEdit { placeholder-text: "wss://relay.example.com"; }
                AppButton {
                    text: "Add relay";
                    clicked => {
                        root.add-relay(relay-input.text);
                        relay-input.text = "";
                    }
                }
            }
        }

        SectionTitle { text: "SENDER KEY"; }
        Card {
            VerticalLayout {
                padding: Theme.pad;
                spacing: 8px;
                Text {
                    text: root.sender-npub == "" ? "Generated on first share" : root.sender-npub;
                    color: Theme.text;
                    font-size: 13px;
                    wrap: word-wrap;
                }
                Text {
                    text: "Your broadcasts are signed by a dedicated key, never a personal Nostr identity. Rotating it unlinks future shares from past ones; receivers will see you as a new sender.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                AppButton { text: "Rotate sender key"; clicked => { root.rotate-sender(); } }
            }
        }

        SectionTitle { text: "ABOUT"; }
        Text {
            text: "ntrack shares your location end-to-end encrypted over Nostr (kind 3434). Locations are encrypted with NIP-44 to your groups' keys; relays only see ciphertext from a pseudonymous sender.";
            color: Theme.muted;
            font-size: 12px;
            wrap: word-wrap;
        }
    }
}

// ------------------------------------------------------------- dialogs --

component ModalScrim inherits Rectangle {
    callback dismiss();
    background: #000000cc;
    // Pull keyboard focus off the page when a dialog opens, so a text caret
    // left behind in an input (e.g. the group-name field after "Create group")
    // stops blinking through the overlay. Inputs inside the dialog still take
    // focus when tapped.
    init => { focus-sink.focus(); }
    focus-sink := FocusScope { width: 0px; height: 0px; }
    TouchArea { clicked => { root.dismiss(); } }
}

// --------------------------------------------------------------- map --

// A round, translucent control overlaid on the map (close, zoom, fit). Icons
// are drawn as vector strokes rather than text glyphs so they never depend on
// a font shipping the symbol (✕/⤢ rendered as tofu on Android).
component MapCtlButton inherits Rectangle {
    // "close" | "plus" | "minus" | "fit"
    in property <string> icon;
    callback clicked;
    width: 40px;
    height: 40px;
    border-radius: 20px;
    background: t.pressed ? Theme.card-alt.brighter(20%) : #1a1d27dd;
    border-width: 1px;
    border-color: Theme.line;
    Path {
        width: 20px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        viewbox-width: 24;
        viewbox-height: 24;
        commands: root.icon == "close" ? "M 5 5 L 19 19 M 19 5 L 5 19"
            : root.icon == "plus" ? "M 12 4 L 12 20 M 4 12 L 20 12"
            : root.icon == "minus" ? "M 4 12 L 20 12"
            : "M 4 9 L 4 4 L 9 4 M 15 4 L 20 4 L 20 9 M 20 15 L 20 20 L 15 20 M 9 20 L 4 20 L 4 15";
        stroke: Theme.text;
        stroke-width: 2px;
        stroke-line-cap: round;
        stroke-line-join: round;
    }
    t := TouchArea { clicked => { root.clicked(); } }
}

// Full-screen live map: OSM raster tiles with a coloured dot per live peer.
// All projection/tiling lives in Rust; this component renders the pushed
// `tiles`/`markers` models and reports gestures back through callbacks.
component MapOverlay inherits Rectangle {
    in property <[MapTile]> tiles;
    in property <[MapMarker]> markers;
    in property <bool> has-peers;
    // Safe-area insets (logical px), forwarded from the Window so the controls
    // and attribution clear the status bar / gesture-navigation bar under
    // edge-to-edge enforcement. The map imagery itself still fills the screen.
    in property <length> inset-top;
    in property <length> inset-bottom;
    in property <length> inset-left;
    in property <length> inset-right;
    callback close();
    callback pan(length, length);
    callback zoom-in();
    callback zoom-out();
    callback fit();
    // Pinch ended: the cumulative scale factor (>1 zoom in, <1 zoom out).
    callback pinch-zoom(float);
    callback viewport(length, length);

    // Live drag offset, applied to tiles + markers together for a smooth pan;
    // committed (and reset) on release once Rust re-centres the view.
    private property <length> pan-x: 0;
    private property <length> pan-y: 0;
    // Live pinch factor (1.0 = none): scales the tile layer about the centre
    // for instant feedback; committed to an integer zoom on release.
    private property <float> pinch-scale: 1.0;

    background: Theme.bg;

    // Catch the Android Back gesture/button so it dismisses the map instead of
    // bubbling up unhandled (which finishes the Activity and exits the app).
    // Grabs focus on open; the map has no text inputs to compete for it.
    init => { back-catcher.focus(); }
    back-catcher := FocusScope {
        width: 0px;
        height: 0px;
        key-pressed(event) => {
            if (event.text == Key.Back || event.text == Key.Escape) {
                root.close();
                return EventResult.accept;
            }
            return EventResult.reject;
        }
    }

    map-area := Rectangle {
        width: 100%;
        height: 100%;
        clip: true;
        // Report the real viewport size so Rust fetches the right tile set.
        init => { root.viewport(self.width, self.height); }
        changed width => { root.viewport(self.width, self.height); }
        changed height => { root.viewport(self.width, self.height); }

        for t in root.tiles : Image {
            x: parent.width / 2 + t.dx * root.pinch-scale + root.pan-x;
            y: parent.height / 2 + t.dy * root.pinch-scale + root.pan-y;
            width: 256px * root.pinch-scale;
            height: 256px * root.pinch-scale;
            source: t.img;
        }

        for m in root.markers : Rectangle {
            x: parent.width / 2 + m.dx * root.pinch-scale + root.pan-x - self.width / 2;
            y: parent.height / 2 + m.dy * root.pinch-scale + root.pan-y - self.height / 2;
            width: 18px;
            height: 18px;
            border-radius: 9px;
            background: m.color;
            border-width: 2px;
            border-color: #ffffff;
            drop-shadow-blur: 4px;
            drop-shadow-color: #000000aa;
            // Name pill above the dot.
            Rectangle {
                y: -22px;
                x: parent.width / 2 - self.width / 2;
                width: lbl.preferred-width + 12px;
                height: 18px;
                border-radius: 9px;
                background: #000000aa;
                lbl := Text {
                    text: m.label;
                    color: #ffffff;
                    font-size: 11px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        drag := TouchArea {
            moved => {
                root.pan-x = self.mouse-x - self.pressed-x;
                root.pan-y = self.mouse-y - self.pressed-y;
            }
            pointer-event(e) => {
                if (e.kind == PointerEventKind.up) {
                    root.pan(root.pan-x, root.pan-y);
                    root.pan-x = 0;
                    root.pan-y = 0;
                } else if (e.kind == PointerEventKind.cancel) {
                    root.pan-x = 0;
                    root.pan-y = 0;
                }
            }
        }

        // Two-finger pinch → zoom. Slint's recogniser suspends the single-touch
        // drag above for the duration, so the two don't fight. `scale` is the
        // cumulative factor since the gesture began (1.0 at start).
        pinch := ScaleRotateGestureHandler {
            updated => { root.pinch-scale = Math.clamp(self.scale, 0.3, 3.0); }
            ended => {
                root.pinch-zoom(self.scale);
                root.pinch-scale = 1.0;
            }
            cancelled => { root.pinch-scale = 1.0; }
        }
    }

    // Empty state — centred on the map so it stays clear of the edge controls.
    if !root.has-peers : Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        width: min(parent.width - 32px, 320px);
        height: hint.preferred-height + 16px;
        border-radius: 10px;
        background: #1a1d27ee;
        hint := Text {
            text: "No one is sharing a live location right now.";
            color: Theme.muted;
            font-size: 13px;
            wrap: word-wrap;
            width: parent.width - 24px;
            horizontal-alignment: center;
        }
    }

    // Close (top-left), clear of the status bar / cutout.
    MapCtlButton {
        x: root.inset-left + 12px;
        y: root.inset-top + 12px;
        icon: "close";
        clicked => { root.close(); }
    }

    // Zoom + fit (right edge), clear of the status bar / cutout.
    VerticalLayout {
        x: parent.width - self.width - 12px - root.inset-right;
        y: root.inset-top + 12px;
        width: 40px;
        spacing: 8px;
        MapCtlButton { icon: "plus"; clicked => { root.zoom-in(); } }
        MapCtlButton { icon: "minus"; clicked => { root.zoom-out(); } }
        MapCtlButton { icon: "fit"; clicked => { root.fit(); } }
    }

    // Attribution — required by the OSM/ODbL tile licence; kept above the
    // gesture-navigation bar so it stays fully readable.
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 6px - root.inset-bottom;
        width: attribution.preferred-width + 12px;
        height: 18px;
        border-radius: 4px;
        background: #000000aa;
        attribution := Text {
            text: "© OpenStreetMap contributors";
            color: #ffffff;
            font-size: 10px;
            vertical-alignment: center;
            horizontal-alignment: center;
        }
    }
}

// ---------------------------------------------------------- main window --

export component MainWindow inherits Window {
    title: "ntrack";
    background: Theme.bg;
    preferred-width: 412px;
    preferred-height: 915px;
    default-font-size: 14px;

    in property <[GroupItem]> groups;
    in property <[TrackItem]> tracks;
    in property <[RelayItem]> relays;
    in property <bool> sharing;
    in property <bool> waiting-fix;
    in property <string> status-headline: "Not sharing";
    in property <string> status-detail: "";
    in property <int> interval-index: 1;
    in property <bool> alert;
    in property <bool> checkin-armed;
    in property <bool> checkin-grace;
    in property <string> checkin-countdown;
    in property <string> sender-npub;
    in property <string> display-name;
    in property <string> default-name;
    in property <bool> can-receive-any;
    in property <string> toast;

    // import form, two-way bound so an incoming invite can pre-fill it
    in-out property <string> import-name-text;
    in-out property <string> import-key-text;

    // share-key dialog payload (filled by Rust before showing)
    in-out property <bool> key-dialog-visible;
    in property <string> key-dialog-name;
    in property <string> key-dialog-npub;
    in property <string> key-dialog-nsec;
    in property <string> key-dialog-invite; // ntrack://join URI: QR + copy/share
    in property <image> key-dialog-qr;

    // rename dialog
    in-out property <bool> rename-dialog-visible;
    in-out property <string> rename-sender;
    in-out property <string> rename-current;

    // confirm dialog (rotate / delete group)
    in-out property <bool> confirm-dialog-visible;
    in property <string> confirm-title;
    in property <string> confirm-body;
    in property <string> confirm-action;

    in-out property <int> current-page: 0;

    // live map overlay (opened from the Track tab)
    in-out property <bool> map-visible;
    in property <[MapTile]> map-tiles;
    in property <[MapMarker]> map-markers;
    in property <bool> map-has-peers;

    callback toggle-group(string, bool);
    callback start-share(string);
    callback stop-share();
    callback set-interval(int);
    callback message-edited(string);
    callback panic();
    callback clear-alert();
    callback arm-checkin(int);
    callback checkin-safe();
    callback checkin-disarm();
    callback open-map(int);
    callback open-map-view();
    callback map-close();
    callback map-pan(length, length);
    callback map-zoom-in();
    callback map-zoom-out();
    callback map-fit();
    callback map-pinch-zoom(float);
    callback map-viewport(length, length);
    callback export-track(int);
    callback rename-sender-confirmed(string, string);
    callback create-group(string);
    callback import-group(string, string);
    callback share-group(string);
    callback rotate-group(string);
    callback delete-group(string);
    callback scan-qr();
    callback paste();
    callback confirm-accepted();
    callback add-relay(string);
    callback remove-relay(string);
    callback rotate-sender();
    callback set-display-name(string);
    callback copy-text(string);
    callback system-share(string);

    init => {
        Palette.color-scheme = ColorScheme.dark;
    }

    VerticalLayout {
        // Keep interactive content clear of side insets (cutout / nav bar in
        // landscape); zero in portrait. `safe-area-insets` is supplied by the
        // Slint Window already in logical pixels and updated reactively on
        // scale/configuration changes, so no manual physical->logical scaling
        // is needed here (all edges are zero on the desktop).
        padding-left: root.safe-area-insets.left;
        padding-right: root.safe-area-insets.right;

        Rectangle { height: root.safe-area-insets.top; background: Theme.bg; }

        // header
        HorizontalLayout {
            padding-left: Theme.pad;
            padding-right: Theme.pad;
            padding-top: 6px;
            padding-bottom: 6px;
            spacing: 8px;
            Text {
                text: "ntrack📍";
                color: Theme.text;
                font-size: 20px;
                font-weight: 800;
                horizontal-stretch: 1;
            }
            if root.sharing : Rectangle {
                width: live.preferred-width + 18px;
                height: 26px;
                border-radius: 13px;
                background: Theme.ok.darker(60%);
                live := Text {
                    text: "SHARING";
                    color: Theme.ok;
                    font-size: 11px;
                    font-weight: 800;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
            // Open the live map (Track tab only).
            if root.current-page == 1 : Rectangle {
                width: maplbl.preferred-width + 26px;
                height: 28px;
                border-radius: 14px;
                background: mapbtn.pressed ? Theme.accent-dim : Theme.accent;
                maplbl := Text {
                    text: "🗺 Map";
                    color: #ffffff;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
                mapbtn := TouchArea { clicked => { root.open-map-view(); } }
            }
        }

        // page area
        Rectangle {
            vertical-stretch: 1;
            clip: true;
            if root.current-page == 0 : SharePage {
                groups: root.groups;
                sharing: root.sharing;
                waiting-fix: root.waiting-fix;
                status-headline: root.status-headline;
                status-detail: root.status-detail;
                interval-index: root.interval-index;
                alert: root.alert;
                checkin-armed: root.checkin-armed;
                checkin-grace: root.checkin-grace;
                checkin-countdown: root.checkin-countdown;
                toggle-group(id, v) => { root.toggle-group(id, v); }
                start-share(msg) => { root.start-share(msg); }
                stop-share => { root.stop-share(); }
                set-interval(i) => { root.set-interval(i); }
                message-edited(m) => { root.message-edited(m); }
                panic => { root.panic(); }
                clear-alert => { root.clear-alert(); }
                arm-checkin(i) => { root.arm-checkin(i); }
                checkin-safe => { root.checkin-safe(); }
                checkin-disarm => { root.checkin-disarm(); }
            }
            if root.current-page == 1 : TrackPage {
                tracks: root.tracks;
                can-receive-any: root.can-receive-any;
                open-map(i) => { root.open-map(i); }
                export-track(i) => { root.export-track(i); }
                rename-request(sender, current) => {
                    root.rename-sender = sender;
                    root.rename-current = current;
                    root.rename-dialog-visible = true;
                }
            }
            if root.current-page == 2 : GroupsPage {
                groups: root.groups;
                import-name-text <=> root.import-name-text;
                import-key-text <=> root.import-key-text;
                create-group(n) => { root.create-group(n); }
                import-group(n, k) => { root.import-group(n, k); }
                share-group(id) => { root.share-group(id); }
                rotate-group(id) => { root.rotate-group(id); }
                delete-group(id) => { root.delete-group(id); }
                scan-qr => { root.scan-qr(); }
                paste => { root.paste(); }
            }
            if root.current-page == 3 : SettingsPage {
                relays: root.relays;
                sender-npub: root.sender-npub;
                display-name: root.display-name;
                default-name: root.default-name;
                add-relay(u) => { root.add-relay(u); }
                remove-relay(u) => { root.remove-relay(u); }
                rotate-sender => { root.rotate-sender(); }
                set-display-name(n) => { root.set-display-name(n); }
            }
        }

        // tab bar
        Rectangle {
            height: 64px;
            background: Theme.card;
            HorizontalLayout {
                padding: 6px;
                spacing: 4px;
                for tab[idx] in ["Share", "Track", "Groups", "Settings"] : Rectangle {
                    border-radius: 10px;
                    background: root.current-page == idx ? Theme.card-alt : transparent;
                    Text {
                        text: tab;
                        color: root.current-page == idx ? Theme.accent.brighter(40%) : Theme.muted;
                        font-size: 14px;
                        font-weight: root.current-page == idx ? 700 : 500;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                    TouchArea { clicked => { root.current-page = idx; } }
                }
            }
        }

        // bottom safe-area inset (gesture / navigation bar) — same colour as
        // the tab bar so it reads as one surface.
        Rectangle { height: root.safe-area-insets.bottom; background: Theme.card; }
    }

    // ---- overlays ----

    if root.map-visible : MapOverlay {
        width: 100%;
        height: 100%;
        tiles: root.map-tiles;
        markers: root.map-markers;
        has-peers: root.map-has-peers;
        inset-top: root.safe-area-insets.top;
        inset-bottom: root.safe-area-insets.bottom;
        inset-left: root.safe-area-insets.left;
        inset-right: root.safe-area-insets.right;
        close => { root.map-close(); }
        pan(dx, dy) => { root.map-pan(dx, dy); }
        zoom-in => { root.map-zoom-in(); }
        zoom-out => { root.map-zoom-out(); }
        fit => { root.map-fit(); }
        pinch-zoom(s) => { root.map-pinch-zoom(s); }
        viewport(w, h) => { root.map-viewport(w, h); }
    }

    if root.key-dialog-visible : ModalScrim {
        dismiss => { root.key-dialog-visible = false; }
        Card {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(parent.width - 32px, 380px);
            height: key-dialog-layout.preferred-height;
            key-dialog-layout := VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                Text {
                    text: "Group key — " + root.key-dialog-name;
                    color: Theme.text;
                    font-size: 16px;
                    font-weight: 700;
                    wrap: word-wrap;
                }
                if root.key-dialog-invite != "" : Rectangle {
                    height: self.width * 0.62;
                    background: #ffffff;
                    border-radius: 8px;
                    Image {
                        source: root.key-dialog-qr;
                        width: parent.height - 16px;
                        height: parent.height - 16px;
                        x: (parent.width - self.width) / 2;
                        y: 8px;
                        image-rendering: pixelated;
                    }
                }
                Text {
                    text: "Scanning this in ntrack pre-fills the group name and key automatically.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                Text {
                    text: root.key-dialog-invite;
                    color: root.key-dialog-nsec != "" ? Theme.warn : Theme.text;
                    font-size: 11px;
                    wrap: char-wrap;
                }
                if root.key-dialog-nsec != "" : Text {
                    text: "This link contains the group secret — anyone with it can read all locations shared with the group. Hand it over in person or via an end-to-end encrypted channel only. If membership changes, rotate the key.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                if root.key-dialog-nsec == "" : Text {
                    text: "Send-only group — this link carries only the public key, so others can send to the group but cannot read it.";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                HorizontalLayout {
                    spacing: 8px;
                    AppButton {
                        text: "Copy";
                        clicked => { root.copy-text(root.key-dialog-invite); }
                    }
                    AppButton {
                        text: "Share…";
                        clicked => { root.system-share(root.key-dialog-invite); }
                    }
                }
                AppButton { text: "Close"; primary: true; clicked => { root.key-dialog-visible = false; } }
            }
        }
    }

    if root.rename-dialog-visible : ModalScrim {
        dismiss => { root.rename-dialog-visible = false; }
        Card {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(parent.width - 32px, 380px);
            height: rename-dialog-layout.preferred-height;
            rename-dialog-layout := VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                Text { text: "Name this sender"; color: Theme.text; font-size: 16px; font-weight: 700; }
                Text {
                    text: "Senders are pseudonymous keys. Give this one a name you recognize (e.g. \"Anna's phone\").";
                    color: Theme.muted;
                    font-size: 12px;
                    wrap: word-wrap;
                }
                rename-input := LineEdit {
                    placeholder-text: "Label";
                    init => { self.text = root.rename-current; }
                }
                HorizontalLayout {
                    spacing: 8px;
                    AppButton { text: "Cancel"; clicked => { root.rename-dialog-visible = false; } }
                    AppButton {
                        text: "Save";
                        primary: true;
                        clicked => {
                            root.rename-sender-confirmed(root.rename-sender, rename-input.text);
                            rename-input.text = "";
                            root.rename-dialog-visible = false;
                        }
                    }
                }
            }
        }
    }

    if root.confirm-dialog-visible : ModalScrim {
        dismiss => { root.confirm-dialog-visible = false; }
        Card {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(parent.width - 32px, 380px);
            height: confirm-dialog-layout.preferred-height;
            confirm-dialog-layout := VerticalLayout {
                padding: Theme.pad;
                spacing: 10px;
                Text { text: root.confirm-title; color: Theme.text; font-size: 16px; font-weight: 700; wrap: word-wrap; }
                Text { text: root.confirm-body; color: Theme.muted; font-size: 13px; wrap: word-wrap; }
                HorizontalLayout {
                    spacing: 8px;
                    AppButton { text: "Cancel"; clicked => { root.confirm-dialog-visible = false; } }
                    AppButton {
                        text: root.confirm-action;
                        danger: true;
                        clicked => {
                            root.confirm-dialog-visible = false;
                            root.confirm-accepted();
                        }
                    }
                }
            }
        }
    }

    if root.toast != "" : Rectangle {
        x: (parent.width - self.width) / 2;
        y: parent.height - 140px;
        width: min(toast-label.preferred-width + 32px, parent.width - 32px);
        height: toast-label.preferred-height + 20px;
        border-radius: 12px;
        background: #2c3040ee;
        toast-label := Text {
            text: root.toast;
            color: Theme.text;
            font-size: 13px;
            wrap: word-wrap;
            width: parent.width - 32px;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
